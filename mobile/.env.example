# ─── API ──────────────────────────────────────────────────────────────────────
# URL of your running Next.js backend.
# Production:  https://identifindsolutions.io  (leave blank to use this default)
# Development: use your machine's local network IP (not localhost — emulators can't reach it).
#   Find it with: ipconfig (Windows) → IPv4 Address
#   Example: http://192.168.1.42:3000
EXPO_PUBLIC_API_URL=https://identifindsolutions.io

# ─── OAuth (must match what's registered in each provider's developer console) ─
# These are the SAME client IDs as in your web .env — the redirect URI is different though.
# For each provider, add a redirect URI for the mobile scheme:
#   identifind://auth/callback
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GITHUB_CLIENT_ID=
EXPO_PUBLIC_LINKEDIN_CLIENT_ID=
EXPO_PUBLIC_TWITTER_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_ID=
