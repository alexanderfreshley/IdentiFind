# ─── Database ─────────────────────────────────────────────────────────────────
# Runtime connection — pooled via PgBouncer (port 6543). Used by all API routes.
# Supabase: Dashboard → Settings → Database → Connection pooling → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection — bypasses PgBouncer (port 5432). Used ONLY by Prisma migrations.
# Supabase: Dashboard → Settings → Database → Connection string → URI
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"
# Production:  https://identifindsolutions.io
# Development: http://localhost:3000
NEXTAUTH_URL="https://identifindsolutions.io"

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting PII at rest. Generate: openssl rand -base64 32
ENCRYPTION_KEY="REPLACE_WITH_STRONG_RANDOM_KEY"
# HMAC pepper for searchable PII indexes. Generate: openssl rand -base64 32
HASH_PEPPER="REPLACE_WITH_STRONG_RANDOM_PEPPER"

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Google (covers YouTube) — https://console.cloud.google.com/
# Production callback:  https://identifindsolutions.io/api/auth/callback/google
# Development callback: http://localhost:3000/api/auth/callback/google
# Mobile callback:      identifind://auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/developers
# Production callback:  https://identifindsolutions.io/api/auth/callback/github
# Development callback: http://localhost:3000/api/auth/callback/github
# Mobile: create a SEPARATE GitHub OAuth App for mobile (only 1 callback URL allowed per app)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# LinkedIn — https://www.linkedin.com/developers/apps
# Production callback:  https://identifindsolutions.io/api/auth/callback/linkedin
# Development callback: http://localhost:3000/api/auth/callback/linkedin
# Mobile callback:      identifind://auth/callback
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Twitter/X — https://developer.twitter.com/en/portal/dashboard
# Production callback:  https://identifindsolutions.io/api/auth/callback/twitter
# Development callback: http://localhost:3000/api/auth/callback/twitter
# Mobile callback:      identifind://auth/callback
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# Meta (Facebook + Instagram) — https://developers.facebook.com/apps/
# Production callback:  https://identifindsolutions.io/api/auth/callback/facebook
# Development callback: http://localhost:3000/api/auth/callback/facebook
# Mobile callback:      identifind://auth/callback
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── SMS / Twilio ─────────────────────────────────────────────────────────────
# Required for phone number verification (Settings → Security → Phone Number).
# Sign up at https://twilio.com/try-twilio — free trial includes ~$15 credit.
#
# 1. Account SID + Auth Token: https://console.twilio.com (top of dashboard)
# 2. Buy a number:             https://console.twilio.com/us1/develop/phone-numbers/manage/buy
#    Pick a number with SMS capability. US numbers start at ~$1.15/month.
#
# In development, leave these blank — the code is printed to the Next.js
# console instead of sent via SMS, so you can complete the flow without a
# Twilio account.
TWILIO_ACCOUNT_SID=""          # starts with AC, e.g. ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=""           # 32-char hex string from Twilio console
TWILIO_PHONE_NUMBER=""         # E.164 format, e.g. +15551234567

# ─── Breach Data APIs ─────────────────────────────────────────────────────────

# Have I Been Pwned (HIBP) — https://haveibeenpwned.com/API/Key
# ~$3.50/month. Required for email breach lookups.
HIBP_API_KEY=""

# DeHashed — https://www.dehashed.com/api
# Requires account. Searches 15B+ breach records by email/username/IP/phone.
DEHASHED_API_KEY=""
DEHASHED_API_EMAIL=""   # your DeHashed account email

# Leak-Lookup — https://leak-lookup.com/api
LEAKLOOKUP_API_KEY=""

# Intelligence X — https://intelx.io/account?tab=developer
# Free tier available (limited results). Indexes dark web, pastes, Tor.
INTELX_API_KEY=""
# Optional override for self-hosted / enterprise IntelX endpoint:
# INTELX_API_BASE="https://2.intelx.io"

# ─── PII Broker APIs ─────────────────────────────────────────────────────────
# Surfaces publicly exposed home addresses, past addresses, phone numbers,
# relatives, and social profiles linked to the user's identity.

# Pipl — https://pipl.com/api/ (enterprise; most comprehensive PII source)
PIPL_API_KEY=""

# PeopleDataLabs — https://www.peopledatalabs.com/ (100 free credits/month)
# Returns current + past addresses, phones, employment, social profiles.
PDL_API_KEY=""

# Whitepages Pro — https://pro.whitepages.com/developer/ (~$0.10/query)
# Returns current + past addresses, phone numbers, and linked relatives.
WHITEPAGES_API_KEY=""

# FullContact — https://www.fullcontact.com/developer/ (good free tier)
# Returns social profiles, employer, and location data linked to an email.
FULLCONTACT_API_KEY=""

# Hunter.io — https://hunter.io/api (25 free searches/month)
# Returns sources where an email appears publicly and associated profiles.
HUNTER_API_KEY=""

# Spokeo Partner API — https://www.spokeo.com/partner (partner access required)
SPOKEO_API_KEY=""

# BeenVerified — https://www.beenverified.com/partner (reseller access required)
BEENVERIFIED_API_KEY=""

# ─── Enterprise / Dark Web Monitoring ────────────────────────────────────────
# SpyCloud — https://spycloud.com/product/consumer-ato-prevention/ (enterprise)
# SPYCLOUD_API_KEY=""
